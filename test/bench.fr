\ Ficl benchmark tests
\ From https://www.theultimatebenchmark.org/
\ and adapted for ficl
\ uses clock and clocks/sec from testmain.c
\ uses jhlocals from softwords
\ uses MARKER from softwords
marker bench-marker

: countup
    0 BEGIN
        1 + DUP
        9999 >
    UNTIL DROP
;

: arithm
  0 BEGIN
    1 + DUP DUP / OVER
    * OVER + OVER -
    DROP DUP 9999 >
  UNTIL DROP
;

: sub1 ;
: sub2  sub1 sub1 ;
: sub3  sub2 sub2 ;
: sub4  sub3 sub3 ;

: nesting
 0 BEGIN
    sub4 1 + DUP 9999 >
 UNTIL DROP
;

: logic
 0 BEGIN
    1 +
    DUP NEGATE
    DUP AND
    DUP OR
    DUP XOR
    DROP
    DUP 9999 >
 UNTIL DROP
;

: stacks
    0 BEGIN
    1 + >R DUP >R DUP >R
    R@ DROP R> DROP
    R@ DROP R> DROP
    R@      R> 9999 >
    UNTIL DROP
;

VARIABLE MEM  1000 ALLOT
: memory
  0 BEGIN
    0 BEGIN
      1 + DUP DUP MEM + C!
          DUP     MEM + C@ DROP
      DUP 999 >
    UNTIL DROP
    1 + DUP 99 >
  UNTIL DROP
;

\ make a table of the tests and number of reps for each
\ approx 1 sec runtime for each test
\ last entry is a sentinel
here
' countup , 10000 ,
' arithm ,  3000 ,
' nesting , 1200 ,
' logic  ,  3300 ,
' stacks ,  2500 ,
' memory ,  350 ,
       0 ,  0 ,
constant marks

clocks/sec 1000 / constant clocks/msec

\ iterate an xt count times and report execution time in msec
: times { xt reps | tstart -- msec }
    clock to tstart
    reps 0 DO
        xt EXECUTE
    LOOP
    clock tstart - clocks/msec / .
;


\ print an integer in a fixed width field
40 constant nbuf
create xbuf nbuf allot

: p%*d  { x width -- }
  width 0> if
    x ['] . xbuf >buf
    xbuf dup strlen dup >r type
    width r> -
    dup 0> if spaces else drop endif
  endif
;

\ print xt name in fixed width field
: p%*xt  { xt width | len -- }
  width 0> if
    xt >name dup to len type
    width len - dup 0> if spaces else drop endif
  endif
;

\ benchmark runner
: bench  ( -- )
  ." test      reps      mSec" cr
  marks dup 2@                 ( -- addr reps xt )
  begin
    dup 10 p%*xt               \ print name
    over 10 p%*d               \ print reps
    swap times cr              ( -- addr ) \ print mSec
    2 cells + dup 2@ dup       ( -- addr reps xt xt ) \ next
  0= until empty
;
bench

bench-marker  \ reclaim dictionary space
